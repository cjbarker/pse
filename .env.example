# --- Database ---
# Async URL used by the app/worker (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://pse:pse@localhost:5432/pse
# Sync URL used by Alembic migrations (psycopg/psycopg2 not required; we use psycopg via asyncpg-less path).
SYNC_DATABASE_URL=postgresql+psycopg://pse:pse@localhost:5432/pse

# --- Crawler ---
PSE_USER_AGENT=PSE/0.1 (+https://github.com/cjbarker/pse)
# Politeness delay between requests to the same host, in seconds.
CRAWL_HOST_DELAY=1.0
# Max number of concurrent fetches per worker.
CRAWL_CONCURRENCY=4
# Per-request timeout in seconds.
CRAWL_TIMEOUT=15.0
# Hard cap on page body size to download (bytes).
CRAWL_MAX_BYTES=2000000
# Default max crawl depth applied to new seeds.
CRAWL_DEFAULT_MAX_DEPTH=3
# Respect robots.txt (set to false only for sites you own).
CRAWL_OBEY_ROBOTS=true

# --- Ranking ---
PAGERANK_DAMPING=0.85
# Blend weights for final search score: w_text * text_rank + w_rank * pagerank.
RANK_WEIGHT_TEXT=1.0
RANK_WEIGHT_PAGERANK=2.0

# --- Self-seeding ---
# When true, domains discovered from clicked results become seeds automatically.
# When false, they land in the discovered-domains review queue.
SELF_SEED_AUTO_ADD=false

# --- Federation ---
# Total wall-clock budget for federated peer queries, in seconds.
FEDERATION_TIMEOUT=3.0

# --- Search ---
SEARCH_PAGE_SIZE=10

# --- MCP server (pse-mcp) ---
# When true, the MCP server also registers mutating/crawl-control tools (seeds,
# crawl, pagerank, reindex, discovered queue, peers). Set false for a read-only
# server that only exposes search/get_page/stats.
PSE_MCP_ADMIN=true
